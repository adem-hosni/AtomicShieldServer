Ref "dashboard_moderatorinvitetoken_to_id_fk_auth_user_id":"auth_user"."id" < "dashboard_moderatorinvitetoken"."to_id"

Ref "dashboard_moderatorinvitetoken_game_server_id_fk_gameservers_id":"gameservers"."id" < "dashboard_moderatorinvitetoken"."game_server_id"

Ref "dashboard_releaseasset_release_id_fk_dashboard_release_id":"dashboard_release"."id" < "dashboard_releaseasset"."release_id"

Ref "detection_reports_hwid_id_fk_anticheat_hwid_id":"anticheat_hwid"."id" < "detection_reports"."hwid_id"

Ref "django_admin_log_content_type_id_fk_django_content_type_id":"django_content_type"."id" < "django_admin_log"."content_type_id"

Ref "django_admin_log_user_id_fk_auth_user_id":"auth_user"."id" < "django_admin_log"."user_id"

Ref "false_positive_reports_ban_id_fk_bans_id":"bans"."id" < "false_positive_reports"."ban_id"

Ref "false_positive_reports_reported_by_id_fk_auth_user_id":"auth_user"."id" < "false_positive_reports"."reported_by_id"

Ref "false_positive_reports_reviewed_by_id_fk_auth_user_id":"auth_user"."id" < "false_positive_reports"."reviewed_by_id"

Ref "gameservers_configurations_id_fk_anticheat_configurations_id":"anticheat_configurations"."id" < "gameservers"."configurations_id"

Ref "gameservers_owner_id_fk_auth_user_id":"auth_user"."id" < "gameservers"."owner_id"

