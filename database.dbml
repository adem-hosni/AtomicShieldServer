Table "announcements" {
  "id" bigint(20) [pk, not null]
  "author_id" int(11) [not null]
  "title" varchar(256) [default: NULL]
  "announcement" longtext [not null]
  "mention_everyone" tinyint(1) [not null]
  "date" datetime(6) [default: NULL]
  "category" varchar(32) [not null]
  "is_pinned" tinyint(1) [not null]
  "is_important" tinyint(1) [not null]
}

Table "announcements_seens" {
  "id" bigint(20) [pk, not null]
  "announcements_id" bigint(20) [not null]
  "user_id" int(11) [not null]
}

Table "anticheat_configurations" {
  "id" bigint(20) [pk, not null]
  "config" longtext [not null]
  "webhooks" longtext [not null]
  "embeds" longtext [not null]
  "server_image" varchar(100) [default: NULL]
}

Table "anticheat_configuration_categories" {
  "id" bigint(20) [pk, not null]
  "name" varchar(32) [not null]
  "description" longtext [not null]
  "icon" varchar(32) [not null]
  "server_type" int(11) [not null]
}

Table "anticheat_config_sections" {
  "id" bigint(20) [pk, not null]
  "category_id" bigint(20) [not null]
  "title" varchar(64) [not null]
  "subtitle" longtext [default: NULL]
  "icon" varchar(64) [not null]
  "tooltip" varchar(128) [not null]
}

Table "anticheat_config_templates" {
  "id" bigint(20) [pk, not null]
  "section_id" bigint(20) [not null]
  "name" varchar(64) [not null]
  "subtitle" longtext [default: NULL]
  "icon" varchar(64) [not null]
  "tip" longtext [default: NULL]
  "pseudo_name" varchar(32) [not null, unique]
  "server_type" int(11) [not null]
  "config_type" longtext [not null]
  "extra" longtext [not null]
  "default_value" varchar(512) [not null]
}

Table "anticheat_version" {
  "id" bigint(20) [pk, not null]
  "major" int(11) [not null]
  "minor" int(11) [not null]
  "patch" int(11) [not null]
  "type" int(11) [not null]
  "entity" int(11) [not null]
  "is_current_version" tinyint(1) [not null]
}

Table "anticheat_hwid" {
  "id" bigint(20) [pk, not null]
  "username" varchar(32) [not null]
  "computer_name" varchar(64) [not null]
  "disks" longtext [not null]
  "cpuid" varchar(64) [not null]
  "motherboard_serial" varchar(64) [not null]
  "bios_version" varchar(32) [not null]
  "pnp_device" varchar(512) [not null]
  "fivem_license" varchar(64) [default: NULL]
  "fivem_token" longtext [not null]
  "steam" varchar(64) [default: NULL]
  "discord_id" varchar(64) [default: NULL]
}

Table "detection_reports" {
  "id" bigint(20) [pk, not null]
  "hwid_id" bigint(20) [default: NULL]
  "detection_type" int(11) [not null]
  "detected_at" datetime(6) [not null]
  "report" longtext [not null]
  "screenshot" varchar(100) [not null]
}

Table "bans" {
  "id" bigint(20) [pk, not null]
  "hwid_id" bigint(20) [default: NULL]
  "banned_at" datetime(6) [not null]
  "duration" bigint(20) [default: NULL]
  "game_server_id" bigint(20) [default: NULL]
  "active" tinyint(1) [not null]
  "reason" varchar(256) [default: NULL]
  "report_id" bigint(20) [default: NULL]
}

Table "false_positive_reports" {
  "id" bigint(20) [pk, not null]
  "ban_id" bigint(20) [not null]
  "reported_by_id" int(11) [not null]
  "reason" longtext [not null]
  "status" varchar(20) [not null]
  "reviewed_by_id" int(11) [default: NULL]
  "reviewed_at" datetime(6) [default: NULL]
  "created_at" datetime(6) [not null]
}

Table "warnings" {
  "id" bigint(20) [pk, not null]
  "hwid_id" bigint(20) [not null]
  "warns" smallint(5) [not null]
}

Table "whitelisted_processes" {
  "id" bigint(20) [pk, not null]
  "name" varchar(64) [not null, unique]
  "type" int(11) [not null]
}

Table "threat_files" {
  "id" bigint(20) [pk, not null]
  "file" varchar(100) [not null]
  "found_path" varchar(256) [not null]
  "hash" varchar(256) [not null]
  "note" varchar(256) [default: NULL]
  "uploaded_by_id" bigint(20) [not null]
  "uploaded_at" datetime(6) [not null]
}

Table "crash_reports" {
  "id" bigint(20) [pk, not null]
  "crash_by_id" bigint(20) [default: NULL]
  "error" varchar(64) [default: NULL]
  "module_base" varchar(64) [default: NULL]
  "exception_code" varchar(32) [default: NULL]
  "exception_address" varchar(32) [default: NULL]
  "exception_flags" varchar(32) [default: NULL]
  "registers" longtext [not null]
  "crashed_at" datetime(6) [not null]
}

Table "malicious_signatures" {
  "id" bigint(20) [pk, not null]
  "name" varchar(64) [not null, unique]
  "signatures" longtext [not null]
  "type" int(11) [not null]
  "priority" int(11) [default: NULL]
  "ban_message" varchar(64) [default: NULL]
  "ban_duaration" bigint(20) [not null]
}

Table "appreloader_application" {
  "id" bigint(20) [pk, not null]
  "name" varchar(255) [not null]
  "label" varchar(255) [not null]
  "path" varchar(255) [not null]
  "module" varchar(255) [not null]
}

Table "auth_group" {
  "id" int(11) [pk, not null]
  "name" varchar(150) [not null]
}

Table "auth_group_permissions" {
  "id" bigint(20) [pk, not null]
  "group_id" int(11) [not null]
  "permission_id" int(11) [not null]
}

Table "auth_permission" {
  "id" int(11) [pk, not null]
  "name" varchar(255) [not null]
  "content_type_id" int(11) [not null]
  "codename" varchar(100) [not null]
}

Table "auth_user" {
  "id" int(11) [pk, not null]
  "password" varchar(128) [not null]
  "last_login" datetime(6) [default: NULL]
  "is_superuser" tinyint(1) [not null]
  "username" varchar(150) [not null]
  "first_name" varchar(150) [not null]
  "last_name" varchar(150) [not null]
  "email" varchar(254) [not null]
  "is_staff" tinyint(1) [not null]
  "is_active" tinyint(1) [not null]
  "date_joined" datetime(6) [not null]
}

Table "auth_user_groups" {
  "id" bigint(20) [pk, not null]
  "user_id" int(11) [not null]
  "group_id" int(11) [not null]
}

Table "auth_user_user_permissions" {
  "id" bigint(20) [pk, not null]
  "user_id" int(11) [not null]
  "permission_id" int(11) [not null]
}

Table "dashboard_release" {
  "id" bigint(20) [pk, not null]
  "version" varchar(32) [not null, unique]
  "title" varchar(200) [not null]
  "description" longtext [not null]
  "release_date" datetime(6) [default: NULL]
  "platform" varchar(50) [not null]
  "format" varchar(20) [not null]
  "stability" varchar(16) [not null]
  "recommended" tinyint(1) [not null]
  "changelog" longtext [not null]
}

Table "dashboard_releaseasset" {
  "id" bigint(20) [pk, not null]
  "release_id" bigint(20) [not null]
  "label" varchar(100) [not null]
  "file" varchar(100) [default: NULL]
  "external_url" longtext [not null]
  "is_primary" tinyint(1) [not null]
}

Table "dashboard_gameservermoderator" {
  "id" bigint(20) [pk, not null]
  "user_id" int(11) [not null, unique]
  "game_server_id" bigint(20) [not null]
  "can_view_dashboard" tinyint(1) [not null]
  "can_view_analytics" tinyint(1) [not null]
  "can_kick_players" tinyint(1) [not null]
  "can_ban_players" tinyint(1) [not null]
  "can_view_anticheat_logs" tinyint(1) [not null]
  "can_manage_configuration" tinyint(1) [not null]
  "can_manage_webhook_settings" tinyint(1) [not null]
  "can_access_interactive_map" tinyint(1) [not null]
  "can_access_multi_stream" tinyint(1) [not null]
  "can_manage_moderators" tinyint(1) [not null]
  "status" varchar(10) [not null]
  "added_at" datetime(6) [default: NULL]
}

Table "dashboard_moderatorinvitetoken" {
  "id" bigint(20) [pk, not null]
  "invited_by_id" int(11) [not null]
  "to_id" int(11) [not null]
  "game_server_id" bigint(20) [not null]
  "permissions" longtext [not null]
  "status" int(11) [not null]
  "token" varchar(128) [not null, unique]
  "invited_at" datetime(6) [default: NULL]
}

Table "dashboard_auditlogentry" {
  "id" bigint(20) [pk, not null]
  "timestamp" datetime(6) [not null]
  "action" smallint(5) [not null]
  "severity" smallint(5) [not null]
  "actor_content_type_id" int(11) [default: NULL]
  "actor_object_id" varchar(128) [default: NULL]
  "category" int(11) [not null]
  "summary" varchar(140) [not null]
  "details" longtext [not null]
  "game_server_id" bigint(20) [default: NULL]
  "target_content_type_id" int(11) [default: NULL]
  "target_object_id" varchar(128) [default: NULL]
  "metadata" longtext [default: NULL]
  "source" varchar(32) [not null]
  "reviewed" tinyint(1) [not null]
}

Table "django_admin_log" {
  "id" int(11) [pk, not null]
  "action_time" datetime(6) [not null]
  "object_id" longtext [default: NULL]
  "object_repr" varchar(200) [not null]
  "action_flag" smallint(5) [not null]
  "change_message" longtext [not null]
  "content_type_id" int(11) [default: NULL]
  "user_id" int(11) [not null]
}

Table "django_content_type" {
  "id" int(11) [pk, not null]
  "app_label" varchar(100) [not null]
  "model" varchar(100) [not null]
}

Table "django_migrations" {
  "id" bigint(20) [pk, not null]
  "app" varchar(255) [not null]
  "name" varchar(255) [not null]
  "applied" datetime(6) [not null]
}

Table "django_session" {
  "session_key" varchar(40) [pk, not null]
  "session_data" longtext [not null]
  "expire_date" datetime(6) [not null]
}

Table "gameservers" {
  "id" bigint(20) [pk, not null]
  "ip" varchar(49) [not null]
  "port" int(11) [not null]
  "name" varchar(32) [not null]
  "owner_id" int(11) [not null]
  "configurations_id" bigint(20) [not null]
  "type" int(11) [default: NULL]
  "status" int(11) [not null]
}

Table "gameservers_subscriptions" {
  "id" bigint(20) [pk, not null]
  "gameserver_id" bigint(20) [not null]
  "serversubscription_id" bigint(20) [not null]
}

Table "patchnotes" {
  "id" bigint(20) [pk, not null]
  "author" varchar(64) [not null]
  "title" varchar(255) [not null]
  "version" varchar(16) [not null]
  "release_type" varchar(10) [not null]
  "status_tags" longtext [not null]
  "highlights" longtext [not null]
  "description" longtext [not null]
  "mention_everyone" tinyint(1) [not null]
  "date" datetime(6) [not null]
}

Table "patchnotes_seens" {
  "id" bigint(20) [pk, not null]
  "patchnotes_id" bigint(20) [not null]
  "user_id" int(11) [not null]
}

Table "payments" {
  "id" bigint(20) [pk, not null]
  "tebex_payment_id" varchar(128) [not null, unique]
  "transaction_id" varchar(512) [not null, unique]
  "customer_id" varchar(64) [not null]
  "customer_firstname" varchar(64) [not null]
  "customer_lastname" varchar(64) [not null]
  "customer_username" varchar(64) [not null]
  "customer_email" longtext [not null]
  "customer_country" varchar(16) [not null]
  "customer_postalcode" varchar(16) [not null]
  "customer_ip" varchar(49) [not null]
  "tebex_date" varchar(32) [not null]
  "status" int(11) [default: NULL]
  "price" int(11) [not null]
  "currency" varchar(16) [not null]
  "payment_method" varchar(64) [not null]
  "payment_refundable" tinyint(1) [default: NULL]
  "tax" int(11) [not null]
  "tax_currency" varchar(16) [not null]
  "gateway_tax" int(11) [not null]
  "creator_code" varchar(256) [default: NULL]
  "coupons" longtext [not null]
  "recurring_payment_refrence" longtext [default: NULL]
  "paid_products" longtext [not null]
}

Table "subscriptions" {
  "id" bigint(20) [pk, not null]
  "owner_id" int(11) [default: NULL]
  "started_at" datetime(6) [default: NULL]
  "key" varchar(32) [not null]
  "payment_id" bigint(20) [default: NULL]
  "plan" int(11) [not null]
  "type" int(11) [default: NULL]
  "status" int(11) [not null]
}

Ref "announcements_author_id_fk_auth_user_id":"auth_user"."id" < "announcements"."author_id"

Ref "announcements_seens_announcements_id_fk_announcements_id":"announcements"."id" < "announcements_seens"."announcements_id"

Ref "announcements_seens_user_id_fk_auth_user_id":"auth_user"."id" < "announcements_seens"."user_id"

