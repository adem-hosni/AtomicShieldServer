Ref "auth_user_user_permissions_user_id_fk_auth_user_id":"auth_user"."id" < "auth_user_user_permissions"."user_id"

Ref "bans_hwid_id_fk_anticheat_hwid_id":"anticheat_hwid"."id" < "bans"."hwid_id"

Ref "bans_game_server_id_fk_gameservers_id":"gameservers"."id" < "bans"."game_server_id"

Ref "bans_report_id_fk_detection_reports_id":"detection_reports"."id" < "bans"."report_id"

Ref "crash_reports_crash_by_id_fk_anticheat_hwid_id":"anticheat_hwid"."id" < "crash_reports"."crash_by_id"

Ref "dashboard_auditlogentry_actor_content_type_id_fk_django_content_type_id":"django_content_type"."id" < "dashboard_auditlogentry"."actor_content_type_id"

Ref "dashboard_auditlogentry_target_content_type_id_fk_django_content_type_id":"django_content_type"."id" < "dashboard_auditlogentry"."target_content_type_id"

Ref "dashboard_auditlogentry_game_server_id_fk_gameservers_id":"gameservers"."id" < "dashboard_auditlogentry"."game_server_id"

Ref "dashboard_gameservermoderator_user_id_fk_auth_user_id":"auth_user"."id" < "dashboard_gameservermoderator"."user_id"

Ref "dashboard_gameservermoderator_game_server_id_fk_gameservers_id":"gameservers"."id" < "dashboard_gameservermoderator"."game_server_id"

