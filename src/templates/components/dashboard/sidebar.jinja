{% load static %}

<button data-drawer-target="cta-button-sidebar" data-drawer-toggle="cta-button-sidebar" aria-controls="cta-button-sidebar" type="button" class="w-max inline-transition-all duration-300 flex items-center p-2 mt-2 ms-3 text-sm text-gray-500 rounded-lg sm:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-[#01a7fc] dark:focus:ring-yellow-600">
  <span class="sr-only">Open sidebar</span>
  <svg class="w-6 h-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z"></path>
  </svg>
</button>

<aside id="cta-button-sidebar" class="fixed top-0 left-0 z-40 w-64 h-screen transition-transform -translate-x-full sm:translate-x-0" aria-label="Sidebar">
  <div class="h-full px-3 py-4 overflow-y-auto bg-[#081017]">
    <a href="/">
      <img src="{% static 'assets/images/logo.png' %}" 
           alt="AtomicShield" 
           class="flex mx-auto mt-3 mb-4" 
           style="width: auto; height: 100px; object-fit: contain;" />
  </a>
      <ul class="space-y-2 font-medium">
      <li>
        <a href="/dashboard/main" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <svg class="w-5 h-5 text-gray-500 transition duration-75 text-gray-400 group-hover:text-gray-900 group-hover:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 22 21">
            <path d="M16.975 11H10V4.025a1 1 0 0 0-1.066-.998 8.5 8.5 0 1 0 9.039 9.039.999.999 0 0 0-1-1.066h.002Z" />
            <path d="M12.5 0c-.157 0-.311.01-.565.027A1 1 0 0 0 11 1.02V10h8.975a1 1 0 0 0 1-.935c.013-.188.028-.374.028-.565A8.51 8.51 0 0 0 12.5 0Z" />
          </svg>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Dashboard</span>
          {% if unseen_announcements > 0 %}
          <span class="inline-transition-all duration-300 flex items-center justify-center w-3 h-3 p-3 ms-3 text-sm font-medium text-zinc-800 bg-yellow-100 rounded-full dark:bg-[#01a7fc] dark:text-zinc-300">{{ unseen_announcements }}</span>
          {% endif %}
        </a>
      </li>
      <li>
        <a href="{% url 'players' %}" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-globe text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Players</span>
        </a>
      </li>
      <li>
        <a href="/dashboard/bans" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-ban text-gray-400 transition duration-75"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Bans</span>
        </a>
      </li>
      <li>
        <a href="/dashboard/servers" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-server text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Servers</span>
        </a>
      </li>
      <li>
        <a href="/dashboard/configurations" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-gears text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Configurations</span>
        </a>
      </li>
      <li>
        <a href="{% url 'quick_setup' %}" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-file-shield text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Quick Setup</span>
        </a>
      </li>
      <li>
        <a href="/dashboard/patch-notes" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <svg class="transition-all duration-300 flex-shrink-0 w-5 h-5 text-gray-500 transition duration-75 dark:text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="m17.418 3.623-.018-.008a6.713 6.713 0 0 0-2.4-.569V2h1a1 1 0 1 0 0-2h-2a1 1 0 0 0-1 1v2H9.89A6.977 6.977 0 0 1 12 8v5h-2V8A5 5 0 1 0 0 8v6a1 1 0 0 0 1 1h8v4a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-4h6a1 1 0 0 0 1-1V8a5 5 0 0 0-2.582-4.377ZM6 12H4a1 1 0 0 1 0-2h2a1 1 0 0 1 0 2Z" />
          </svg>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Patch Notes</span>
          {% if unseen_patchnotes > 0 %}
          <span class="inline-transition-all duration-300 flex items-center justify-center w-3 h-3 p-3 ms-3 text-sm font-medium text-zinc-800 bg-yellow-100 rounded-full dark:bg-[#01a7fc] dark:text-zinc-300">{{ unseen_patchnotes }}</span>
          {% endif %}
        </a>
      </li>
      <li>
        <a href="/dashboard/subscriptions" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-money-check-dollar text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Subscriptions</span>
        </a>
      </li>
      <li>
        <a href="{{ discord_invite }}" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-[#01a7fc] group">
          <i class="fa-solid fa-envelope text-gray-400"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap">Support</span>
        </a>
      </li>
      <li>
        <a href="/auth/logout" class="transition-all duration-300 flex items-center p-2 text-gray-900 rounded-lg dark:text-white hover:bg-gray-100 dark:hover:bg-red-700 group">
          <i class="fa-solid fa-arrow-right-from-bracket text-red-500"></i>
          <span class="transition-all duration-300 flex-1 ms-3 whitespace-nowrap text-red-500">Log Out</span>
        </a>
      </li>
    </ul>
    {% for pin in cta_pins %}
    <div id="dropdown-cta-{{ pin.id }}" class="p-4 mt-6 rounded-lg bg-[#01a7fc] transition-all duration-300" role="alert">
      <div class="transition-all duration-300 flex items-center mb-3">
        <span class="bg-orange-100 text-orange-800 text-sm font-semibold me-2 px-2.5 py-0.5 rounded dark:bg-orange-200 dark:text-orange-900">{{ pin.title }}</span>
        <button type="button" onclick="localStorage.setItem('hide-cta-{{ pin.id }}', '1');" class="ms-auto -mx-1.5 -my-1.5 bg-yellow-50 inline-transition-all duration-300 flex justify-center items-center w-6 h-6 text-[#01a7fc] rounded-lg focus:ring-2 focus:ring-yellow-400 p-1 hover:bg-yellow-200 dark:bg-[#01a7fc] dark:text-zinc-400 dark:hover:bg-yellow-800" data-dismiss-target="#dropdown-cta-{{ pin.id }}" aria-label="Close">
          <span class="sr-only">Close</span>
          <svg class="w-2.5 h-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
          </svg>
        </button>
      </div>
      <p class="mb-3 text-sm text-zinc-800 dark:text-zinc-400">{{ pin.description }}</p>
        <a href="{{ pin.extra_url.url }}" class="text-sm text-zinc-800 underline font-medium hover:text-[#01a7fc] dark:text-zinc-400 dark:hover:text-zinc-300">{{ pin.extra_url.text }}</a>
    </div>
    {% endfor %}
  </div>
</aside>

<script>
  const CTAs = {{ cta_pins|safe }};
  CTAs.forEach(cta => {
      if (localStorage.getItem(`hide-cta-${cta.id}`) == "1") {
          document.getElementById(`dropdown-cta-${cta.id}`).hidden = true;
      } else {
        console.log("reset");
          localStorage.setItem(`hide-cta-${cta.id}`, "0")
      }
  });
</script>
