{% extends "bases/dashboard.jinja" %}
{% block content %}

<div
  class="p-4 rounded-lg transition-all duration-300 bg-[#081017]"
>
  {% include "components/dashboard/breadcrumb.jinja" with current_page="Bans" %}
</div>
<section
    class="flex-1 px-4 rounded-lg transition-all duration-300 bg-[#081017] grid grid-rows-[auto,1fr] my-4"
  >
    <div class="flex flex-wrap w-full flex grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-2 justify-center py-6 text-center gap-6">
      <div class="bg-[#09121e] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-users text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Total Banned Players</p>
          <p class="text-xl font-semibold text-white counter">{{ bans|length }}</p>
        </div>
      </div>

      <div class="bg-[#09121e] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-ban text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Total Detections</p>
          <p class="text-xl font-semibold text-white counter">{{ detections }}</p>
        </div>
      </div>
    </div>
</section>

<div class="relative overflow-x-auto shadow-md sm:rounded-lg">
  <table
    class="w-full text-sm text-left rtl:text-right text-gray-400 overflow-x-hidden"
  >
    <thead
      class="text-xs uppercase bg-[#081017] text-gray-400"
    >
      <tr>
        <th scope="col" class="px-3 py-3">NAME</th>
        <th scope="col" class="pl-3 py-3">BANNED AT</th>
        <th scope="col" class="pl-3 py-3">LICENSE</th>
        <th scope="col" class="pl-3 py-3">STEAM</th>
        <th scope="col" class="pl-3 py-3">DISCORD ID</th>
        <th scope="col" class="pl-3 py-3">DURATION</th>
        <th scope="col" class="pl-3 py-3">STATUS</th>
        <th scope="col" class="pl-3 py-3">REASON</th>
        <th scope="col" class="pl-3 py-3">Actions</th>
      </tr>
    </thead>
    <tbody>

      {% for ban in bans %}
      <tr class="transition-all duration:300 border-b bg-[#0E1B23] border-gray-700 hover:bg-[#142733]">
        <td class="px-6 py-4 font-medium">{{ ban.username }}</td>
        
        <td class="px-1 py-4">{{ ban.banned_at }}</td>
        <td class="px-1 py-4">{{ ban.license }}</td>
        <td class="px-1 py-4">{{ ban.steam }}</td>
        <td class="px-1 py-4">{{ ban.discord_id }}</td>
        <td class="pl-3 py-4">Permanent</td>
        <td class="pl-6 py-4">
          {% if ban.status == 2 %}
            <span class="px-2 border font-medium border-zinc-300 rounded p-1 text-zinc-300 transition-all duration-300 hover:bg-zinc-300 hover:text-black select-none">EXPIRED</span>
          {% elif ban.status == 1 %}
            <span class="px-2 border font-medium border-red-500 rounded p-1 text-red-500 transition-all duration-300 hover:bg-red-500 hover:text-black select-none">BANNED</span>
          {% elif ban.status == 0 %}
            <span class="px-2 border font-medium border-yellow-600 rounded p-1 text-yellow-600 transition-all duration-300 hover:bg-yellow-600 hover:text-black select-none">UNBANNED</span>
          {% endif %}
        </td>
        <td class="pl-6 py-4 font-bold">{{ ban.reason }}</td>
        {% if ban.status != 2 %}
          <td class="pl-6 py-4 flex">
            <button
              onclick="document.getElementById('target-ban').value = '{{ ban.id }}'; 
              document.getElementById('target-ban-modal-name').textContent = '{{ ban.username }}';
              document.getElementById('target-ban-op').textContent = {{ ban.status }} == 1 ? 'Unban' : 'Ban';
              document.getElementById('op-type').value = {{ ban.status }} == 1 ? 'unban' : 'ban';"

              data-modal-target="change-ban-state"
              data-modal-toggle="change-ban-state"
              data-tooltip-target="bantooltip--{{ ban.id }}"
              data-tooltip-style="dark"
              class="font-medium text-blue-500 hover:underline"
            >
              <i
                class="fa-regular fa-circle-check text-[#01e4f4] transition-all duration-300 hover:bg-[#01e4f4] hover:text-black rounded-full p-1"
              ></i>
            </button>
            
            <button
              data-modal-target="screenshot-modal"
              data-modal-toggle="screenshot-modal"
              data-tooltip-target="screenshot-tooltip--{{ ban.id }}"
              data-tooltip-style="dark"
              class="font-medium text-blue-500 hover:underline"
              onclick="setScreenshot('{{ ban.username }}', '{{ ban.screenshot_url }}')"
            >
              <i
                class="fa-solid fa-display text-[#01e4f4] transition-all duration-300 hover:bg-[#01e4f4] hover:text-black rounded-full p-1"
              ></i>
            </button>

            <div
              id="bantooltip--{{ ban.id }}"
              role="tooltip"
              class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#01e4f4] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300"
            >
              {% if ban.status == 1 %}
                Unban
              {% elif ban.status == 0%}
                Ban
              {% endif %}
              <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
            <div
              id="screenshot-tooltip--{{ ban.id }}"
              role="tooltip"
              class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#01e4f4] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300"
            >
              Screenshot Proof
              <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
          </td>
          {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if bans|length == 0 %}
  <div
    class="transition-all duration:300 border-b bg-[#0E1B23] border-gray-700 hover:bg-[#142733] flex text-center"
  >
  <div scope="row" class="px-6 py-4 font-medium whitespace-nowrap text-gray-400 hover:text-white w-full">0 Bans</div>
  </div>
  {% endif %}
</div>

<div
  id="change-ban-state"
  tabindex="-1"
  aria-hidden="true"
  class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full"
>
  <div class="relative p-4 w-full max-w-md max-h-full">
    <!-- Modal content -->
    <div class="relative rounded-lg shadow bg-[#081017]">
      <!-- Modal header -->
      <div
        class="flex items-center justify-between p-4 md:p-5 border-b rounded-t border-gray-600"
      >
        <h3 class="text-xl font-semibold text-white">
          Manage Ban
        </h3>
        <button
          data-modal-hide="change-ban-state"
          type="button"
          class="end-2.5 text-gray-400 bg-transparent rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center hover:bg-[#01e4f4] hover:text-black"
        >
          <svg
            class="w-3 h-3"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 14 14"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
            />
          </svg>
          <span class="sr-only">Close modal</span>
        </button>
      </div>
      <!-- Modal body -->
      <div class="p-4 md:p-5">
        <p class="text-center text-lg text-gray-300">
          Are you sure to <span id="target-ban-op"></span>
          <span id="target-ban-modal-name" class="font-bold"></span
          > ?
        </p>
        <form class="space-y-4" method="post">
          {% csrf_token %}
          <input id="op-type" type="hidden" name="type" value="delete" />
          <input
            type="hidden"
            id="target-ban"
            name="target-ban"
            value=""
          />
          <button type="submit" value="" onclick="this.disabled=true; this.form.submit();" class="w-full flex items-center justify-center self-stretch px-4 py-2 rounded-xl z-10 border text-white-gray border-[#91a6b633] hover:bg-[#00A7FD] hover:text-[#081017] hover:border-[#00A7FD] hover:drop-shadow-[0rem_0rem_1rem_#00A7FD] transition-all duration-300">
            <div class="text-[0.9375rem] font-publicsans font-medium leading-[1.5rem]">Yes</div>
          </button>
        </form>
        <button
          data-modal-hide="change-ban-state"
          onclick="this.disabled=true; this.form.submit();"
          class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Start Screenshot Modal -->
<div
id="screenshot-modal"
tabindex="-1"
aria-hidden="true"
class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full"
>
<div class="relative p-4 w-full max-w-md max-h-full">
  <!-- Modal content -->
  <div class="relative rounded-lg shadow bg-[#081017]">
    <!-- Modal header -->
    <div
      class="flex items-center p-4 md:p-5 border-b rounded-t border-gray-600"
    >
      <h3
        id="modal-player-name"
        class="text-xl font-semibold text-white ml-2"
      >Screenshot</h3>
    </div>
    <!-- Modal body -->
    <div class="p-4 md:p-5">
        <div id="screenshot-container" class="w-full h-46 bg-gray-200 overflow-hidden shadow-lg">
          <img src=""
          alt="Screenshot" class="hidden w-full h-full object-cover" id="player-screenshot">
        </div>

        <div class="flex mt-4 ">
          <div id="download-tooltip" role="tooltip" class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#00A7FD] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300">
            Download
            <div class="tooltip-arrow" data-popper-arrow></div>
          </div>
          <a href="" download="Screenshot.png" id="download-btn" class="hidden ml-auto w-max flex items-center justify-center self-stretch px-4 py-2 rounded-xl z-10 border text-white-gray border-[#91a6b633] hover:bg-[#00A7FD] hover:text-[#081017] hover:border-[#00A7FD] hover:drop-shadow-[0rem_0rem_1rem_#00A7FD] transition-all duration-300 cursor-pointer"
            data-tooltip-target="download-tooltip"
          >
            <div class="text-[0.9375rem] font-publicsans font-medium leading-[1.5rem]">
              <i class="flex fa-solid fa-download"></i></div>
          </a>
        </div>

      <button
        data-modal-hide="screenshot-modal"
        class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3"
      >
        Close
      </button>
    </div>
  </div>
</div>
</div>

<script>
  function setScreenshot(playerName, screenshotUrl) {
    document.getElementById("modal-player-name").innerText = `${playerName}'s Screenshot`;
    document.getElementById("player-screenshot").src = screenshotUrl;
      document.getElementById("download-btn").href = screenshotUrl;
      document.getElementById("player-screenshot").classList.remove("hidden");
      document.getElementById("download-btn").classList.remove("hidden");
      document.getElementById("screenshot-container").classList.remove("hidden");
  }
</script>

<!-- End Screenshot Modal -->
{% endblock content %}