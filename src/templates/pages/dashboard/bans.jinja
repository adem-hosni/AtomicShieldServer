{% extends "bases/dashboard.jinja" %}
{% block content %}

<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#081017]"
>
  {% include "components/dashboard/breadcrumb.jinja" with current_page="Bans" %}
</div>
<section
    class="flex-1 px-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#081017] grid grid-rows-[auto,1fr] my-4"
  >
    <div class="flex flex-wrap w-full flex grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-2 justify-center py-6 text-center gap-6">
      <div class="bg-[#081017] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-users text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Total Joined Users</p>
          <p class="text-xl font-semibold text-white counter">78,4567</p>
        </div>
      </div>

      <div class="bg-[#081017] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-ban text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Detections</p>
          <p class="text-xl font-semibold text-white counter">153,081</p>
        </div>
      </div>
    </div>
</section>

<div class="relative overflow-x-auto shadow-md sm:rounded-lg">
  <table
    class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400"
  >
    <thead
      class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-[#081017] dark:text-gray-400"
    >
      <tr>
        <th scope="col" class="px-6 py-3">NAME</th>
        <th scope="col" class="px-3 py-3">GAME SERIAL</th>
        <th scope="col" class="px-3 py-3">BANNED AT</th>
        <th scope="col" class="pl-3 py-3">DURATION</th>
        <th scope="col" class="pl-6 py-3">STATUS</th>
        <th scope="col" class="pl-6 py-3">REASON</th>
        <th scope="col" class="px-6 py-3">Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for ban in bans %}
      <tr class="transition-all duration:300 border-b bg-[#0E1B23] border-gray-700 hover:bg-[#142733]">
        <td class="px-6 py-4 font-medium">{{ ban.username }}</td>

        <td
          scope="row"
          class="px-3 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white cursor-pointer"
          onclick="navigator.clipboard.writeText('{{ ban.key }}').then(() => iziToast.success({title: 'SUCCESS', message: 'Successfuly key copied to clipboard!'}))"
        >
          <span class="blur-sm hover:blur-0 transition duration-300">{{ ban.game_serial }}</span>
        </td>
        
        <td class="px-1 py-4">{{ ban.banned_at }}</td>
        <td class="px-3 py-4">{{ ban.duration }}</td>
        <td class="px-6 py-4">
          {% if ban.status == 2 %}
            <span class="px-2 border font-medium border-zinc-300 rounded p-1 text-zinc-300 transition-all duration-300 hover:bg-zinc-300 hover:text-black select-none">EXPIRED</span>
          {% elif ban.status == 1 %}
            <span class="px-2 border font-medium border-red-500 rounded p-1 text-red-500 transition-all duration-300 hover:bg-red-500 hover:text-black select-none">BANNED</span>
          {% elif ban.status == 0 %}
            <span class="px-2 border font-medium border-yellow-600 rounded p-1 text-yellow-600 transition-all duration-300 hover:bg-yellow-600 hover:text-black select-none">UNBANNED</span>
          {% endif %}
        </td>
        <td class="px-6 py-4 font-bold">{{ ban.reason }}</td>
        {% if ban.status != 2 %}
          <td class="px-6 py-4 flex">
            <button
              onclick="document.getElementById('target-ban').value = '{{ ban.id }}'; 
              document.getElementById('target-ban-modal-name').textContent = '{{ ban.username }}';
              document.getElementById('target-ban-op').textContent = {{ ban.status }} == 1 ? 'Unban' : 'Ban';
              document.getElementById('op-type').value = {{ ban.status }} == 1 ? 'unban' : 'ban';"

              data-modal-target="change-ban-state"
              data-modal-toggle="change-ban-state"
              data-tooltip-target="bantooltip--{{ ban.id }}"
              data-tooltip-style="dark"
              class="font-medium text-blue-600 dark:text-blue-500 hover:underline"
            >
              <i
                class="fa-regular fa-circle-check text-[#01e4f4] transition-all duration-300 hover:bg-[#01e4f4] hover:text-black rounded-full p-1"
              ></i>
            </button>

            <div
              id="bantooltip--{{ ban.id }}"
              role="tooltip"
              class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#01e4f4] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300"
            >
              {% if ban.status == 1 %}
                Unban
              {% elif ban.status == 0%}
                Ban
              {% endif %}
              <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
          </td>
          {% endif %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if bans|length == 0 %}
  <div
    class="transition-all duration:300 bg-white border-b dark:bg-[#0E1B23] dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-[#181818] flex text-center"
  >
    <div
      scope="row"
      class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white w-full"
    >
      No bans were found
    </div>
  </div>
  {% endif %}
</div>

<div
  id="change-ban-state"
  tabindex="-1"
  aria-hidden="true"
  class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full"
>
  <div class="relative p-4 w-full max-w-md max-h-full">
    <!-- Modal content -->
    <div class="relative bg-white rounded-lg shadow dark:bg-[#081017]">
      <!-- Modal header -->
      <div
        class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600"
      >
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
          Manage Ban
        </h3>
        <button
          type="button"
          class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-purple-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#01e4f4] dark:hover:text-black"
        >
          <svg
            class="w-3 h-3"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 14 14"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
            />
          </svg>
          <span class="sr-only">Close modal</span>
        </button>
      </div>
      <!-- Modal body -->
      <div class="p-4 md:p-5">
        <p class="text-center text-lg text-gray-300">
          Are you sure to <span id="target-ban-op"></span>
          <span id="target-ban-modal-name" class="font-bold"></span
          > ?
        </p>
        <form class="space-y-4" method="post">
          {% csrf_token %}
          <input id="op-type" type="hidden" name="type" value="delete" />
          <input
            type="hidden"
            id="target-ban"
            name="target-ban"
            value=""
          />
          <button
            type="submit"
            value=""
            onclick="this.disabled=true; this.form.submit();"
            class="w-full text-black border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 border-[#01e4f4] bg-[#01e4f4] hover:bg-[#b37339]"
          >
            Yes
          </button>
        </form>
        <button
          data-modal-hide="change-ban-state"
          onclick="this.disabled=true; this.form.submit();"
          class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock content %}