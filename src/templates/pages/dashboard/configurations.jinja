{% extends 'bases/dashboard.jinja' %} {% block content %}
<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#08101777]"
>
  {% include 'components/dashboard/breadcrumb.jinja' with current_page='Configurations' %}
</div>

<div class="w-full bg-[#08101777] p-6 rounded-xl mt-4" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-[#0e3638] text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-gear opacity-20"></i>
          <i class="absolute fa fa-gear"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <div
          class="flex items-center justify-center mr-3 bg-input rounded-full text-lg bg-transparent"
        >
          <i class="fa fa-brackets-curly text-blue-500"></i>
        </div>
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Configurations
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">
        Configure your selected server anticheats
      </h4>
    </div>
  </div>
</div>
<div class="mt-4 flex flex-col items-stretch item-center justify-center">
  <div class="gap-3 rounded-xl bg-[#08101777] px-6 py-2.5 space-y-2 items-center">
    <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
      <ul
        class="flex flex-wrap -mb-px text-sm font-medium text-center"
        id="default-styled-tab"
        data-tabs-toggle="#default-styled-tab-content"
        data-tabs-active-classes="text-[#01e4f4] hover:text-[#01e4f4] dark:text-[#01e4f4] dark:hover:text-[#01e4f4] border-[#01e4f4] dark:border-[#01e4f4]"
        data-tabs-inactive-classes="dark:border-transparent text-gray-500 hover:text-gray-600 dark:text-gray-400 border-gray-100 hover:border-gray-300 dark:border-gray-700 dark:hover:text-gray-300"
        role="tablist"
      >
        {% for configuration in configurations %}
        <li role="presentation">
          <button
            class="transition-all duration-300 inline-block p-4 border-b-2 rounded-t-lg hover:text-[#b37339] hover:border-[#b37339] dark:hover:text-[#01e4f4]"
            id="c{{ configuration.id }}-tab"
            data-tabs-target="#c{{ configuration.id }}"
            type="button"
            role="tab"
            aria-controls="c{{ configuration.id }}"
            aria-selected="false"
          >
            {{ configuration.name }}
          </button>
        </li>
        {% endfor %}
      </ul>
    </div>
    <div id="default-styled-tab-content">
      {% for configuration in configurations %}
      <div
        class="hidden"
        id="c{{ configuration.id }}"
        role="tabpanel"
        aria-labelledby="c{{ configuration.id }}-tab"
      >
        <div class="rounded-lg bg-[#01e4f4] p-4">
          <p class="text-sm text-black font-medium">
            {{ configuration.description }}
          </p>
        </div>
        <div class="p-1">
          <form method="POST">
            {% csrf_token %} {% for field in configuration.fields %}
            <div class="flex flex-col w-full p-4">
              <label
                for="{{ field.id }}"
                class="font-medium text-gray-300 pb-2"
                >{{ field.name }}</label
              >

              <div class="flex flex-wrap">
                <p class="text-gray-400 font-medium text-sm px-2">
                  {{ field.description }}
                </p>

                <label
                  class="transition-all duration-300 inline-flex items-center cursor-pointer ml-auto"
                >
                  {% if field.type == 1 %} {% if field.value %}
                  <input
                    type="checkbox"
                    name="{{ field.id }}"
                    class="sr-only peer"
                    checked
                  />
                  {% else %}
                  <input
                    type="checkbox"
                    name="{{ field.id }}"
                    class="sr-only peer"
                  />
                  {% endif %}
                  <div
                    class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-[#0e3638] peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-[#01e4f4] hover:peer-checked:bg-[#b37339] active:peer-checked:bg-[#7f4c1e] transition-all duration-300"
                  ></div>
                </label>

                {% elif field.type == 2 %}
                <div class="relative h-10 w-64 min-w-[200px] ml-auto">
                  <input
                    name="{{ field.id }}"
                    value="{{ field.value }}"
                    placeholder="Type Here..."
                    class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
                  />
                  <label
                    class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >
                    Type Here...
                  </label>
                </div>
                {% elif field.type == 3 %}
                <div class="relative h-10 w-16 min-w-[100px] ml-auto">
                  <input
                    name="{{ field.id }}"
                    value="{{ field.value }}"
                    placeholder="Type Here..."
                    type="number"
                    class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
                  />
                  <label
                    class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >
                    Type a number
                  </label>
                </div>
                {% endif %}
              </div>
            </div>

            {% if forloop.counter != configuration.fields|length %}
            <hr class="my-2 border-t-2 border-[#01e4f4] w-[100%] mx-auto" />
            {% endif %} {% endfor %}
            <div class="flex w-full justify-end gap-3">
              <input type="hidden" name="type" value="save">
              <button
                type="button"
                data-modal-target="reset-config-modal"
                data-modal-toggle="reset-config-modal"
                class="bg-transparent border border-2 border-red-700 px-3 py-1 rounded-lg font-medium text-red-700 transition-all duration-300 hover:bg-red-700 hover:text-black">Reset</button>
              <input
                type="submit"
                value="Save"
                class="px-3 py-1 w-21 font-medium cursor-pointer bg-[#01e4f4] transition-all duration-300 hover:bg-[#b37339] active:bg-[#7f4c1e] text-black rounded-lg"
              />
            </div>
          </form>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<div
  id="reset-config-modal"
  tabindex="-1"
  aria-hidden="true"
  class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full"
>
  <div class="relative p-4 w-full max-w-md max-h-full">
    <!-- Modal content -->
    <div class="relative bg-white rounded-lg shadow dark:bg-[#08101777]">
      <!-- Modal header -->
      <div
        class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600"
      >
        <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
          Reset Configurations
        </h3>
        <button
          type="button"
          class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-purple-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#01e4f4] dark:hover:text-black"
        >
          <svg
            class="w-3 h-3"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 14 14"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"
            />
          </svg>
          <span class="sr-only">Close modal</span>
        </button>
      </div>
      <!-- Modal body -->
      <div class="p-4 md:p-5">
        <p class="text-center text-lg text-gray-300">
          Are you sure to reset your server configurations ?
        </p>
        <form class="space-y-4" method="post">
          {% csrf_token %}
          <input type="hidden" name="type" value="reset" />
          <button
            type="submit"
            value=""
            onclick="this.disabled=true; this.form.submit();"
            class="w-full text-black border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 border-[#01e4f4] bg-[#01e4f4] hover:bg-[#b37339]"
          >
            Yes, Reset
          </button>
        </form>
        <button
          data-modal-hide="reset-config-modal"
          onclick="this.disabled=true; this.form.submit();"
          class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3"
        >
          No, Don't reset
        </button>
      </div>
    </div>
  </div>
</div>

{% endblock %}
