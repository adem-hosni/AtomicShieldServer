{% extends 'bases/dashboard.jinja' %} {% block content %}
<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#0c0c0c]"
>
  {% include 'components/dashboard/breadcrumb.jinja' with current_page='Configurations' %}
</div>

<div class="w-full bg-[#0D0D0D] p-6 rounded-xl mt-4" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-zinc-900 text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-gear opacity-20"></i>
          <i class="absolute fa fa-gear"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <div
          class="flex items-center justify-center mr-3 bg-input rounded-full text-lg bg-transparent"
        >
          <i class="fa fa-brackets-curly text-blue-500"></i>
        </div>
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Configurations
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">
        Configure your selected server anticheats
      </h4>
    </div>
  </div>
</div>
<div class="mt-4 flex flex-col items-stretch item-center justify-center">
  <div class="gap-3 rounded-xl bg-[#0D0D0D] px-6 py-2.5 space-y-2 items-center">
    <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
      <ul
        class="flex flex-wrap -mb-px text-sm font-medium text-center"
        id="default-styled-tab"
        data-tabs-toggle="#default-styled-tab-content"
        data-tabs-active-classes="text-[#8c592b] hover:text-[#8c592b] dark:text-[#8c592b] dark:hover:text-[#8c592b] border-[#8c592b] dark:border-[#8c592b]"
        data-tabs-inactive-classes="dark:border-transparent text-gray-500 hover:text-gray-600 dark:text-gray-400 border-gray-100 hover:border-gray-300 dark:border-gray-700 dark:hover:text-gray-300"
        role="tablist"
      >
        {% for configuration in configurations %}
        <li role="presentation">
          <button
            class="transition-all duration-300 inline-block p-4 border-b-2 rounded-t-lg hover:text-[#b37339] hover:border-[#b37339] dark:hover:text-[#8c592b]"
            id="c{{ configuration.id }}-tab"
            data-tabs-target="#c{{ configuration.id }}"
            type="button"
            role="tab"
            aria-controls="c{{ configuration.id }}"
            aria-selected="false"
          >
            {{ configuration.name }}
          </button>
        </li>
        {% endfor %}
      </ul>
    </div>
    <div id="default-styled-tab-content">
      {% for configuration in configurations %}
      <div
        class="hidden"
        id="c{{ configuration.id }}"
        role="tabpanel"
        aria-labelledby="c{{ configuration.id }}-tab"
      >
        <div class="rounded-lg bg-[#8c592b] p-4">
          <p class="text-sm text-black">
            {{ configuration.description }}
          </p>
        </div>
        <div class="p-1">
          <form method="POST">
            {% csrf_token %}
            {% for field in configuration.fields %}
            <div class="flex flex-col w-full p-4">
              <label
                for="{{ field.id }}"
                class="font-medium text-gray-300 pb-2"
                >{{ field.name }}</label
              >

              <div class="flex">
                <p class="text-gray-400 font-medium text-sm px-2">
                  {{ field.description }}
                </p>

                <label
                  class="transition-all duration-300 inline-flex items-center cursor-pointer ml-auto"
                >
                  {% if field.type == 1 %} {% if field.value %}
                  <input
                    type="checkbox"
                    name="{{ field.id }}"
                    class="sr-only peer"
                    checked
                  />
                  {% else %}
                  <input
                    type="checkbox"
                    name="{{ field.id }}"
                    class="sr-only peer"
                  />
                  {% endif %}
                  <div
                    class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-zinc-900 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-[#8c592b] hover:peer-checked:bg-[#b37339] active:peer-checked:bg-[#7f4c1e] transition-all duration-300"
                  ></div>
                </label>

                {% elif field.type == 2 %}
                <div class="relative h-10 w-64 min-w-[200px] ml-auto">
                  <input
                    name="{{ field.id }}"
                    value="{{ field.value }}"
                    placeholder="Type Here..."
                    class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#8c592b] selection:text-black"
                  />
                  <label
                    class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >
                    Type Here...
                  </label>
                </div>
                {% elif field.type == 3 %}
                <div class="relative h-10 w-16 min-w-[100px] ml-auto">
                  <input
                    name="{{ field.id }}"
                    value="{{ field.value }}"
                    placeholder="Type Here..."
                    type="number"
                    class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#8c592b] selection:text-black"
                  />
                  <label
                    class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >
                    Type a number
                  </label>
                </div>
                {% endif %}
              </div>
            </div>

            {% if forloop.counter != configs|length %}
            <hr class="my-2 border-t-2 border-[#8c592b] w-[100%] mx-auto" />
            {% endif %} {% endfor %}
            <input
              type="submit"
              value="Save"
              class="px-3 py-1 font-medium cursor-pointer bg-[#8c592b] transition-all duration-300 hover:bg-[#b37339] active:bg-[#7f4c1e] text-black rounded-lg flex ml-auto"
            >
          </form>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endblock %}
