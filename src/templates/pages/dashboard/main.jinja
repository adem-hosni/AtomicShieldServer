{% extends "bases/dashboard.jinja" %} {% block content %}
<div
  class="p-4 rounded-lg transition-all duration-300 bg-[#081017]"
>
  {% include "components/dashboard/breadcrumb.jinja" with current_page="Dashboard" %}
</div>

<div class="flex flex-col">
  <!-- Main content area -->
  <main
    class="flex-1 p-4 rounded-lg transition-all duration-300 bg-[#081017] grid grid-rows-[auto,1fr] my-4"
  >
    <h1
      href="#"
      class="text-2xl transition-all duration-300 ms-1 font-medium md:ms-2 text-gray-400 min-w-44 hover:text-white"
    >
      👋 Welcome Back
      <span
        style="filter: drop-shadow(0px 0px 10px #01e4f4)"
        class="text-[#01e4f4]"
        >{{ username }}</span
      >
    </h1>
    <div class="flex flex-wrap w-full flex grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 justify-center py-6 gap-6">
      <div class="bg-[#09121e] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-user-shield text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Online Scanners</p>
          <p class="text-xl font-semibold text-white counter">{{ online_scanners }}</p>
        </div>
      </div>

      <div class="bg-[#09121e] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-ban text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Detections</p>
          <p class="text-xl font-semibold text-white counter">{{ detection_count }}</p>
        </div>
      </div>

      <div class="bg-[#09121e] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#0e3638]"
        >
          <i class="fa-solid fa-users text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Banned Players</p>
          <p class="text-xl font-semibold text-white counter">{{ banned_players }}</p>
        </div>
      </div>
    </div>
  </main>
</div>
<div class="w-full bg-[#081017] p-6 rounded-xl" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-[#0e3638] text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-bullhorn opacity-20"></i>
          <i class="absolute fa fa-bullhorn"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Announcements
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">Latest Anticheat news</h4>
    </div>
  </div>
  {% for announcement in announcements %}
  <div class="mt-4 flex flex-col items-stretch">
    <div
      class="flex items-center gap-3 rounded-xl bg-[#09121e] px-6 py-2.5 md:flex {% if not announcement.seen %}notification{% endif %} "
      {% if not announcement.seen %}
      data-id="{{ announcement.dataid }}"
      {% endif %}
    >
      <div class="flex flex-col w-full">
        <div class="flex">
          <p class="text-white font-medium">{{ announcement.title }}</p>
          {% if not announcement.seen %}
            <h1 class="text-black bg-[#01e4f4] rounded-full ml-auto w-4 h-4 text-center"></h1>
            {% endif %}
        </div>
        <p class="text-sm text-gray-400 p-1">{{ announcement.announcement }}</p>
        <p class="line-clamp-1 text-xs font-semibold text-[#01e4f4]">
            {{ announcement.author }}. <span class="text-xs text-gray-400"> - {{ announcement.date }}</span>
        </p>
      </div>
    </div>
    {% endfor %}
  </div>
</div>

<script>
  function makeAnnouncementSeen(announcementId) {
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '{% url "main" %}', true);
    xhr.setRequestHeader('X-CSRFToken', '{{ csrf_token }}')
    xhr.send(JSON.stringify({seenAnnouncement: announcementId}));
  }

  const observerCallback = (entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        makeAnnouncementSeen(entry.target.dataset.id);
        entry.target.classList.remove('unseen');
        observer.unobserve(entry.target);
      }
    })
  }

  const observer = new IntersectionObserver(observerCallback, {
    rootMargin: '0px',
    threshold: 0.1 // Trigger when 10% of the element is visible
  });

  const notifications = document.querySelectorAll('.notification');
  notifications.forEach(notification => {
    observer.observe(notification);
  });
</script>
{% endblock content %}
