{% extends "bases/dashboard.jinja" %} {% block content %}
<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#0c0c0c]"
>
  {% include "components/dashboard/breadcrumb.jinja" with current_page="Dashboard" %}
</div>

<div class="flex flex-col">
  <!-- Main content area -->
  <main
    class="flex-1 p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#0c0c0c] grid grid-rows-[auto,1fr] my-4"
  >
    <h1
      href="#"
      class="text-2xl transition-all duration-300 ms-1 font-medium text-gray-700 hover:text-blue-600 md:ms-2 dark:text-gray-400 min-w-44 dark:hover:text-white"
    >
      👋 Welcome Back
      <span
        style="filter: drop-shadow(0px 0px 10px rgb(147 51 234))"
        class="text-purple-600"
        >{{ username }}</span
      >
    </h1>
    <div class="flex flex-wrap w-full flex grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 justify-center py-6 text-center gap-6">
      <div class="bg-[#141414] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900"
        >
          <i class="fa-solid fa-server text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Online Players</p>
          <p class="text-xl font-semibold text-white counter">223 / 4096</p>
        </div>
      </div>

      <div class="bg-[#141414] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900"
        >
          <i class="fa-solid fa-ban text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Detections</p>
          <p class="text-xl font-semibold text-white counter">153,081</p>
        </div>
      </div>

      <div class="bg-[#141414] h-max p-6 flex gap-4 rounded-xl">
        <div
          class="flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-900"
        >
          <i class="fa-solid fa-users text-gray-200 text-lg"></i>
        </div>
        <div class="flex flex-col">
          <p class="text-zinc-400 font-medium text-sm">Banned Players</p>
          <p class="text-xl font-semibold text-white counter">153,081</p>
        </div>
      </div>
    </div>
  </main>
</div>
<div class="w-full bg-[#0D0D0D] p-6 rounded-xl" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-zinc-900 text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-bullhorn opacity-20"></i>
          <i class="absolute fa fa-bullhorn"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <div
          class="flex items-center justify-center mr-3 bg-input rounded-full text-lg bg-transparent"
        >
          <i class="fa fa-brackets-curly text-blue-500"></i>
        </div>
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Announcements
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">Announcements</h4>
    </div>
  </div>
  {% for announcement in announcements %}
  <div class="mt-4 flex flex-col items-stretch">
    <div
      class="flex items-center gap-3 rounded-xl bg-[#161616] px-6 py-2.5 md:flex"
    >
      <div class="flex flex-col">
        <p class="text-white font-medium">{{ announcement.title }}</p>
        <p class=" text-sm text-gray-400">
          {{ announcement.announcement }}
        </p>
        <p class="line-clamp-1 text-xs font-semibold text-purple-600">
            {{ announcement.author }}. <span class="text-xs text-gray-400"> - {{ announcement.date }}</span>
        </p>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock content %}
