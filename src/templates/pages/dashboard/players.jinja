{% extends 'bases/dashboard.jinja' %} {% block content %}
<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#081017]"
>
  {% include 'components/dashboard/breadcrumb.jinja' with current_page='Players' %}
</div>

<div class="w-full bg-[#081017] p-6 rounded-xl mt-4" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-[#0e3638] text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-globe opacity-20"></i>
          <i class="absolute fa fa-globe"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Players
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">
        Manage your online players in your server from the dashboard
      </h4>
    </div>
  </div>
</div>

<div
  class="w-full bg-[#081017] py-6 px-3 items-center rounded-xl mt-4 gap-6"
  style="overflow-y: auto"
  id="file-container"
>
  <!-- Start Input Search -->
  <form method="get">
    <div class="flex gap-1 transition-all duration-300">
      <div class="relative h-10 w-64 min-w-[200px] ml-auto mb-4">
        <input
          id="search"
          name="search"
          placeholder="Search for"
          class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
          oninput="document.getElementById('search-btn').classList.remove('hidden');"
          onblur="
        const element = document.getElementById('search-btn');
        document.getElementById('search').value.length == 0 ? element.classList.add('hidden') : element.classList.remove('hidden');"
        />
        <label
          class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
        >
          Search for
        </label>
      </div>
      <button
        id="search-btn"
        class="hidden transition-all duration-300 flex h-10 px-4 rounded-lg bg-[#0e3638] hover:bg-[#019aa4]"
        type="submit"
      >
        <i class="fa-solid fa-magnifying-glass flex my-auto"></i>
      </button>
    </div>
  </form>
  <!-- End Input Search -->

  <div class="flex flex-wrap gap-4 items-center justify-center">
    {% for player in players %}
    <!-- Start Players -->
    <div class="flex items-stretch">
      <div
        class="flex items-center gap-3 rounded-xl bg-[#09121e] hover:bg-[#019aa4] transition-all duration-300 w-56 px-4 py-2.5 md:flex cursor-pointer"
        data-modal-target="show-info-modal"
        data-modal-toggle="show-info-modal"
        data-tooltip-target="edit-server-tooltip-{{ server.id }}"
        onclick="setPlayerInfo({{ player | safe }})"
      >
        <div class="flex flex-col w-full">
          <div class="flex">
            <p class="text-white font-medium font-bold">
              <span class="text-[#01e4f4]">[{{ player.id }}]</span>
              {{ player.name }}
            </p>
          </div>

          <p class="line-clamp-1 text-xs font-semibold text-[#01e4f4]">
            Ping:<span class="text-xs text-gray-400"> {{ player.ping }}</span>
          </p>
        </div>
      </div>
    </div>
    {% endfor %}
    <!-- End Players -->

    {% if message|length %}
      <h1 class="text-gray-400 font-bold text-xl">{{ message }}</h1>
    {% endif %}

    <!-- Start Pagination -->
    {% if max_pages > 1 %}
    <div
      class="w-full items-center justify-center text-center ml-auto mt-2 flex gap-2 font-bold"
    >
      {% if show_previous %}
      <div
        class="rounded-lg mb-2 px-3 py-2 bg-[#0e3638] hover:bg-sky-400 transition-all duration-300 active:scale-95 w-max justify-end cursor-pointer text-gray-300 hover:text-gray-200 select-none"
        onclick="updateUrlParam('page', {{ current_page }} - 1)"
      >
        &#60;
      </div>
      {% endif %} {% for i in page_range %}
      <div
        class="{% if i == current_page %} bg-sky-400 {% endif %} rounded-lg mb-2 px-3 py-2 bg-[#0e3638] hover:bg-sky-400 transition-all duration-300 active:scale-95 w-max justify-end cursor-pointer text-gray-300 hover:text-gray-200 select-none"
        onclick="updateUrlParam('page', {{ i }})"
      >
        {{ i }}
      </div>
      {% endfor %} {% if show_next %}
      <div
        class="rounded-lg mb-2 px-3 py-2 bg-[#0e3638] hover:bg-sky-400 transition-all duration-300 active:scale-95 w-max justify-end cursor-pointer text-gray-300 hover:text-gray-200 select-none"
        onclick="updateUrlParam('page', {{ current_page }} + 1)"
      >
        &#62;
      </div>
      {% endif %}
    </div>
    {% endif %}
    <!-- End Pagination -->
  </div>
</div>

<!-- Start Show Player Info Modal -->
<div
  id="show-info-modal"
  tabindex="-1"
  aria-hidden="true"
  class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full"
>
  <div class="relative p-4 w-full max-w-md max-h-full">
    <!-- Modal content -->
    <div class="relative bg-white rounded-lg shadow dark:bg-[#081017]">
      <!-- Modal header -->
      <div
        class="flex items-center p-4 md:p-5 border-b rounded-t dark:border-gray-600"
      >
        <span
          id="modal-player-id"
          class="text-xl font-semibold text-[#01e4f4]"
        ></span>
        <h3
          id="modal-player-name"
          class="text-xl font-semibold text-gray-900 dark:text-white ml-2"
        ></h3>
      </div>
      <!-- Modal body -->
      <div class="p-4 md:p-5">
        <form class="space-y-4" method="post">
          {% csrf_token %}
          <input type="hidden" name="type" value="edit" />
          <input type="hidden" name="target_player_id" value="" />

          <div class="space-y-1">
            <div>
              <span class="font-semibold">Steam ID: </span>
              <span class="text-[#01e4f4]" id="steamid"></span>
            </div>
            <div>
              <span class="font-semibold">Discord ID: </span>
              <span class="text-[#01e4f4]" id="discordid"></span>
            </div>
            <div>
              <span class="font-semibold">License: </span>
              <span class="text-[#01e4f4]" id="license"></span>
            </div>
            <div>
              <span class="font-semibold">License 2: </span>
              <span class="text-[#01e4f4]" id="license2"></span>
            </div>
          </div>

          <h4 class="text-gray-400 text-xs">Player Actions:</h4>

          <button type="button" class="w-full flex items-center justify-center self-stretch px-4 py-2 rounded-xl z-10 border text-white-gray border-[#91a6b633] hover:bg-[#00A7FD] hover:text-[#081017] hover:border-[#00A7FD] hover:drop-shadow-[0rem_0rem_1rem_#00A7FD] transition-all duration-300">
            <div class="text-[0.9375rem] font-publicsans font-medium leading-[1.5rem]">Take Screenshot</div>
          </button>
          <div class="w-full flex gap-2">
            <button type="button" class="w-full flex items-center justify-center self-stretch px-4 py-2 rounded-xl z-10 border text-white-gray border-[#91a6b633] hover:bg-amber-600 hover:text-[#081017] hover:border-[#d97706] hover:drop-shadow-[0rem_0rem_1rem_#d97706] transition-all duration-300">
              <div class="text-[0.9375rem] font-publicsans font-medium leading-[1.5rem]">Kick</div>
            </button>
            <button type="button" class="w-full flex items-center justify-center self-stretch px-4 py-2 rounded-xl z-10 border text-white-gray border-[#91a6b633] hover:bg-amber-600 hover:text-[#081017] hover:border-[#d97706] hover:drop-shadow-[0rem_0rem_1rem_#d97706] transition-all duration-300">
              <div class="text-[0.9375rem] font-publicsans font-medium leading-[1.5rem]">Ban</div>
            </button>
          </div>
        </form>
        <button
          data-modal-hide="show-info-modal"
          class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3"
        >
          Cancel
        </button>
      </div>
    </div>
  </div>
</div>
<!-- End Show Player Info Modal -->

<script>
  function updateUrlParam(param, value) {
    const url = new URL(window.location);
    url.searchParams.set(param, value);
    window.location.href = url;
  }

  function setPlayerInfo(playerInfo) {
    document.getElementById("modal-player-name").innerText = playerInfo["name"];
    document.getElementById(
      "modal-player-id"
    ).innerText = `[${playerInfo["id"]}]`;
    document.getElementById("steamid").innerText = playerInfo["steamid"];
    document.getElementById("discordid").innerText = playerInfo["discordid"];
    document.getElementById("license").innerText = playerInfo["license"];
    document.getElementById("license2").innerText = playerInfo["license2"];

    document.getElementById("target_player_id").value = playerInfo["id"];
  }
</script>

{% endblock %}
