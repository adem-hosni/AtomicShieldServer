{% extends 'bases/dashboard.jinja' %} {% load static %} {% block content %}
  <div class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#081017]">
    {% include 'components/dashboard/breadcrumb.jinja' with current_page='Servers' %}
  </div>
  
  <script src="{% static 'vendor/iziToast/js/iziToast.js' %}"></script>

  <div class="w-full bg-[#081017] p-6 rounded-xl mt-4" style="overflow-y: auto">
    <div class="flex items-center mb-4 md:mb-0 gap-3">
      <div>
        <div class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-[#0e3638] text-white transition-all duration-300">
          <div class="flex items-center justify-center relative w-8 h-8 undefined">
            <i class="absolute fas fa-server opacity-20"></i>
            <i class="absolute fa fa-server"></i>
          </div>
        </div>
      </div>
      <div class="w-full">
        <div class="flex items-center gap-1">
          <h3 class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1">Servers</h3>
        </div>
        <h4 class="text-gray-400 text-sm">All your AtomicShield Servers are here</h4>
      </div>
    </div>
  </div>
  <div class="w-full p-4 justify-end flex">
    <button data-modal-target="add-server-modal" data-modal-toggle="add-server-modal" class="border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-gray-200 border-gray-200 hover:bg-gray-200 hover:text-black">Add Server</button>
  </div>

  <div class="relative overflow-x-auto shadow-md sm:rounded-lg">
    <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-[#081017] dark:text-gray-400">
        <tr>
          <th scope="col" class="px-6 py-3">Key</th>
          <th scope="col" class="pl-1 py-3">Name</th>
          <th scope="col" class="px-3 py-3">Address</th>
          <th scope="col" class="px-6 py-3">Type</th>
          <th scope="col" class="px-1 py-3">Subscription</th>
          <th scope="col" class="px-6 py-3">STATE</th>
          <th scope="col" class="px-6 py-3">SELECTED</th>
          <th scope="col" class="px-6 py-3">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for server in servers %}
          <tr class="transition-all duration:300 border-b bg-[#0E1B23] border-gray-700 hover:bg-[#142733]">
            <th scope="row" class="px-4 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white cursor-pointer" onclick="navigator.clipboard.writeText('{{ server.key }}').then(() => iziToast.success({title: 'SUCCESS', message: 'Successfuly key copied to clipboard!'}))">
              <span class="blur-sm hover:blur-0 transition duration-300">{{ server.key }}</span>
            </th>
            <td class="pl-1 py-4 whitespace-nowrap font-medium">{{ server.name }}</td>
            <td class="px-3 py-4">{{ server.ip }}:{{ server.port }}</td>
            <td class="px-6 py-4">
              {% if server.type == 1 %}
              <div class="border w-16 text-center font-medium border-[#E87C00] rounded p-1 text-[#E87C00] transition-all duration-300 hover:bg-[#E87C00] hover:text-black select-none">MTA:SA</div>
              {% elif server.type == 2 %}
                <div class="border w-16 text-center font-medium border-[#4B6EA9] rounded p-1 text-[#4B6EA9] transition-all duration-300 hover:bg-[#4B6EA9] hover:text-black select-none">FiveM</div>
              {% endif %}
            </td>
            <td class="px-1 py-4">{{ server.subscription_status }}</td>
            <td class="px-6 py-3">
              {% if server.status %}
                <div class="flex items-center">
                  <div class="block mr-3 outline rounded-full ml-1 h-1 w-1 bg-green-500 outline-green-200 dark:outline-green-500/20"></div>
                  <span class="font-medium">Online</span>
                </div>
              {% else %}
                <div class="flex items-center">
                  <div class="block mr-3 outline rounded-full ml-1 h-1 w-1 bg-red-500 outline-red-200 dark:outline-red-500/20"></div>
                  <span class="font-medium">Offline</span>
                </div>
              {% endif %}
            </td>
            {% if active == server.id %}
              <td class="px-6 py-4"><button onclick="select('{{ server.id }}', false)" class="border py-1 px-2 rounded font-medium text-blue-500 border-blue-500 transition-all duration-300 hover:text-black hover:bg-blue-500 w-20">UnSelect</button></td>
            {% else %}
              <td class="px-6 py-4"><button onclick="select('{{ server.id }}', true)" class="border py-1 px-2 rounded font-medium text-red-500 border-red-500 transition-all duration-300 hover:text-black hover:bg-red-500 w-20">Select</button></td>
            {% endif %}
            <td class="px-6 py-4">
              <button onclick="document.getElementById('target-edit-server').value = '{{ server.id }}';
                              document.getElementById('target-edit-server-name').textContent = '{{ server.name }}';
                              document.getElementById('edit-server-name').value = '{{ server.name }}';
                              document.getElementById('edit-server-ip').value = '{{ server.ip }}';
                              document.getElementById('edit-server-port').value = '{{ server.port }}';"
              data-modal-target="edit-server-modal" data-modal-toggle="edit-server-modal" data-tooltip-target="edit-server-tooltip-{{ server.id }}" data-tooltip-style="dark" class="font-medium text-blue-600 dark:text-blue-500 hover:underline"><i class="fa-solid fa-pen-to-square text-[#01e4f4] transition-all duration-300 hover:bg-[#01e4f4] hover:text-black rounded-full p-1"></i></button>
  

              <button onclick="document.getElementById('target-refresh-server').value = '{{ server.id }}'" data-modal-target="refresh-key-modal" data-modal-toggle="refresh-key-modal" data-tooltip-target="tooltip-refresh-{{ server.id }}" data-tooltip-style="dark" class="font-medium text-blue-600 dark:text-blue-500 hover:underline"><i class="fa-solid fa-arrows-rotate text-[#01e4f4] transition-all duration-300 hover:bg-[#01e4f4] hover:text-black rounded-full p-1"></i></button>

              <div id="edit-server-tooltip-{{ server.id }}" role="tooltip" class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#01e4f4] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300">
                Edit Server
                <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
              <div id="tooltip-refresh-{{ server.id }}" role="tooltip" class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#01e4f4] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300">
                Refresh key
                <div class="tooltip-arrow" data-popper-arrow></div>
            </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if servers|length == 0 %}
        <div class="transition-all duration:300 bg-white border-b dark:bg-[#161616] dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-[#142733] flex text-center">
          <div scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white w-full">0 Servers</div>
        </div>
      {% endif %}
  </div>

  <!-- Main modal -->
  <div id="add-server-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
      <!-- Modal content -->
      <div class="relative bg-white rounded-lg shadow dark:bg-[#081017]">
        <!-- Modal header -->
        <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mx-auto">Add Server</h3>
          <button type="button" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-purple-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#01e4f4] dark:hover:text-black" data-modal-hide="add-server-modal">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
            </svg>
            <span class="sr-only">Close modal</span>
          </button>
        </div>
        <!-- Modal body -->
        <div class="p-4 md:p-5">
          <div id="server-status-div" class="hidden rounded-lg border-2 w-full text-center border-purple-500 py-2 transition-all duration-300 hover:bg-purple-500 group">
            <h1 id="server-status" class="font-medium text-red-500 group-hover:text-black select-none">Invalid Server IP Address</h1>
          </div>
          <form class="space-y-4" method="post" id="addserver-form">
            {% csrf_token %}
            <input type="hidden" name="type" value="add">
            <div class="flex">
              <div class="relative mx-auto w-full">
                {{ form.ip }}
                <label class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300">Server IP Address</label>
              </div>
              <div class="relative w-18">
                {{ form.port }}
                <label class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300">Server Port</label>
              </div>
            </div>
            <div class="relative">
              {{ form.server_name }}
              <label class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300">Server Name</label>
            </div>
            <div class="relative mx-auto">{{ form.server_type }}</div>
            <div class="relative mx-auto">{{ form.subscription }}</div>
            <button type="submit" id="addserver-btn" onclick="this.disabled=true; this.form.submit();" class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-[#01e4f4] border-[#01e4f4] hover:bg-[#01e4f4] hover:text-black">Generate Key</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <!-- Start Refresh key Modal -->
  <div id="refresh-key-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
      <!-- Modal content -->
      <div class="relative bg-white rounded-lg shadow dark:bg-[#081017]">
        <!-- Modal header -->
        <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Refresh Server Key</h3>
          <button type="button" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-purple-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#01e4f4] dark:hover:text-black">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
            </svg>
            <span class="sr-only">Close modal</span>
          </button>
        </div>
        <!-- Modal body -->
        <div class="p-4 md:p-5">
          <p class="text-center text-lg text-gray-300">Are you sure to refresh your server key ?</p>
          <form class="space-y-4" method="post" id="refreshkey-form" action="{% url 'refresh_key' %}">
            {% csrf_token %}
            <input type="hidden" id="target-refresh-server" name="server" value="">
            <button type="submit"  id="refreshkey-btn" value="" onclick="this.disabled=true; this.form.submit();" class="w-full text-black border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 border-[#01e4f4] bg-[#01e4f4] hover:bg-[#b37339]">Yes, Refresh</button>
          </form>
          <button data-modal-hide="refresh-key-modal" onclick="this.disabled=true; this.form.submit();" class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3">No, Don't Refresh</button>

        </div>
      </div>
    </div>
  </div>
  <!-- End Refresh key Modal -->

  <!-- Start Edit Server Modal -->
  <div id="edit-server-modal" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
      <!-- Modal content -->
      <div class="relative bg-white rounded-lg shadow dark:bg-[#081017]">
        <!-- Modal header -->
        <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600">
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Edit <span id="target-edit-server-name"></span>'s Server</h3>
          <button type="button" class="end-2.5 text-gray-400 bg-transparent hover:bg-gray-200 hover:text-purple-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-[#01e4f4] dark:hover:text-black">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
            </svg>
            <span class="sr-only">Close modal</span>
          </button>
        </div>
        <!-- Modal body -->
        <div class="p-4 md:p-5">
          <form class="space-y-4" method="post">
            {% csrf_token %}
            <input type="hidden" name="type" value="edit">
            <input type="hidden" id="target-edit-server" name="target-server" value="">

            <div class="relative mx-auto w-full">
              <input
                type="text"
                name="server-name"
                placeholder="Server Name"
                id="edit-server-name"
                class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
                required=""
              />
              <label
                class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                >Server Name</label
              >
            </div>
            
            <div class="flex">
              <div class="relative mx-auto w-full">
                <input
                  type="text"
                  name="server-ip"
                  placeholder="Server IP"
                  id="edit-server-ip"
                  class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
                  required=""
                />
                <label
                  class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >Server IP</label
                >
              </div>
              <div class="relative mx-auto w-18">
                <input
                  type="number"
                  name="server-port"
                  placeholder="Server Port"
                  id="edit-server-port"
                  class="peer h-full w-full rounded-lg border border-gray-200 border-t-transparent bg-transparent px-3 py-2.5 font-sans text-sm font-normal text-gray-300 outline outline-0 transition-all placeholder-shown:border placeholder-shown:border-gray-300 placeholder-shown:border-t-gray-200 focus:border-gray-300 focus:border-t-transparent focus:outline-0 disabled:border-0 disabled:bg-gray-300 placeholder:opacity-0 focus:placeholder:opacity-100 focus:placeholder-transparent selection:bg-[#01e4f4] selection:text-black"
                  required=""
                />
                <label
                  class="before:content[' '] after:content[' '] pointer-events-none absolute left-0 -top-1.5 flex h-full w-full select-none !overflow-visible truncate text-[11px] font-normal leading-tight text-gray-300 transition-all before:pointer-events-none before:mt-[6.5px] before:mr-1 before:box-border before:block before:h-1.5 before:w-2.5 before:rounded-tl-md before:border-t before:border-l before:border-gray-300 before:transition-all after:pointer-events-none after:mt-[6.5px] after:ml-1 after:box-border after:block after:h-1.5 after:w-2.5 after:flex-grow after:rounded-tr-md after:border-t after:border-r after:border-gray-300 after:transition-all peer-placeholder-shown:text-sm peer-placeholder-shown:leading-[3.75] peer-placeholder-shown:text-gray-300 peer-placeholder-shown:before:border-transparent peer-placeholder-shown:after:border-transparent peer-focus:text-[12px] peer-focus:leading-tight peer-focus:text-gray-300 peer-focus:after:border-t-2 peer-focus:after:border-r-2 peer-focus:after:!border-gray-300 peer-disabled:text-transparent peer-disabled:before:border-transparent peer-disabled:after:border-transparent peer-disabled:peer-placeholder-shown:text-gray-300"
                  >Server Port</label
                >
              </div>
            </div>
            

            <button type="submit" value="" onclick="this.disabled=true; this.form.submit();" class="w-full text-black border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 border-[#01e4f4] bg-[#01e4f4] hover:bg-[#b37339]">Save</button>
          </form>
          <button data-modal-hide="edit-server-modal" onclick="this.disabled=true; this.form.submit();" class="w-full border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-red-600 border-red-600 hover:bg-red-600 hover:text-black my-3">Cancel</button>

        </div>
      </div>
    </div>
  </div>
  <!-- End Edit Server Modal -->

  <script type="text/javascript">
    function select(targetServerId, select) {
      const xhr = new XMLHttpRequest();
      xhr.open('POST', '/dashboard/servers/select', true)
      xhr.setRequestHeader('Content-Type', 'application/json')
      xhr.setRequestHeader('X-CSRFToken', '{{ csrf_token }}')

      xhr.onload = () => {
        var response = JSON.parse(xhr.responseText);
        if (response["success"]) {
          iziToast.success({title: "SUCCESS", message: "Successfuly Server UnSelected"});
          setTimeout(() => location.reload(), 500);
        } else {
          console.log(response)
          iziToast.error({title: "Failure", message: response["message"] || "Unkown Error Occured"});
        }
      };
      xhr.onerror = (err) => console.log(err);

      xhr.send(JSON.stringify(
        {
          "select": select,
          "server_id": targetServerId,
        }
      ));
    }

    document.getElementById('addserver-form').addEventListener('submit', function (event) {
      document.getElementById('addserver-btn').disabled = true
    })
    
    document.addEventListener('DOMContentLoaded', function () {
      const ipRegex = /\b((25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\.){3}(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\b/
    
      const serverIp = document.getElementById('server-ip')
      const serverPort = document.getElementById('server-port')
      const serverStatusDiv = document.getElementById('server-status-div')
      const serverStatus = document.getElementById('server-status')
    
      var portVerified = false
      var ipVerified = false
    
      function setStatusColor(success) {
        if (success) {
          serverStatusDiv.classList.remove('hover:bg-red-500')
          serverStatusDiv.classList.add('hover:bg-green-500')
    
          serverStatus.classList.remove('text-red-500')
          serverStatus.classList.add('text-green-500')
    
          serverStatusDiv.classList.remove('border-red-500')
          serverStatusDiv.classList.add('border-green-500')
        } else {
          serverStatusDiv.classList.remove('hover:bg-green-500')
          serverStatusDiv.classList.add('hover:bg-red-500')
    
          serverStatus.classList.remove('text-green-500')
          serverStatus.classList.add('text-red-500')
    
          serverStatusDiv.classList.remove('border-green-500')
          serverStatusDiv.classList.add('border-red-500')
        }
      }
    
      function checkServer() {
        if (ipVerified && portVerified) {
          const xhr = new XMLHttpRequest()
          xhr.open('POST', '/dashboard/checkserver', true)
          xhr.setRequestHeader('Content-Type', 'application/json')
          xhr.setRequestHeader('X-CSRFToken', '{{ csrf_token }}')
    
          xhr.onload = function () {
            if (xhr.readyState === XMLHttpRequest.DONE) {
              let response = JSON.parse(xhr.responseText)
              serverStatusDiv.style.display = 'block'
    
              setStatusColor(response['success'])
    
              if (response['success']) {
                serverStatus.innerText = `Server Online!
                  Server Name: ${response['servername']}
                  Players: ${response['playercount']}/${response['maxplayers']}
                  Game Type: ${response['gametype']}`
              } else {
                serverStatus.innerText = 'Server Offline'
                return
              }
            }
          }
    
          xhr.onerror = (err) => console.log(err)
          xhr.send(
            JSON.stringify({
              ip: serverIp.value,
              port: serverPort.value,
              server_type: document.getElementById('server-type')?.value
            })
          )
        }
      }
    
      serverIp.addEventListener('input', function (ev) {
        if (!ipRegex.test(serverIp.value)) {
          setStatusColor(false)
          serverStatusDiv.style.display = 'block'
          serverStatus.innerText = 'Invalid Server IP Address'
        } else {
          serverStatusDiv.style.display = 'none'
          ipVerified = true
          checkServer()
        }
      })
    
      serverPort.addEventListener('input', function (ev) {
        const port = Number(serverPort.value)
        if (!(Number.isInteger(port) && port >= 1 && port <= 65535)) {
          serverStatusDiv.style.display = 'block'
          setStatusColor(false)
    
          serverStatus.innerText = 'Invalid Server IP Port'
        } else {
          serverStatusDiv.style.display = 'none'
          portVerified = true
          checkServer()
        }
      })
    })

  </script>
{% endblock %}
