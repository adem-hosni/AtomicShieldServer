<script>
  const sendXhr = (enabled) => {
    const xhr = new XMLHttpRequest();
    xhr.open("POST", "{% url 'whitelist' %}", true);
    xhr.setRequestHeader("X-CSRFToken", "{{ csrf_token }}");
    xhr.setRequestHeader("Content-Type", "application/json");

    xhr.onload = () => {
      const response = { success: true, message: "yeeee!!!" }; //JSON.parse(xhr.responseText);
      if (!response["success"]) {
        iziToast.error({ title: "ERROR", message: response["message"] });
      }
    };
    xhr.send(
      JSON.stringify({
        "enable-whitelist": enabled,
      })
    );
  };

  document.addEventListener("DOMContentLoaded", () => {
    const checkbox = document.getElementById("enable-whitelist");

    let lastTime = Math.floor(Date.now() / 1000);
    let lastCheck = checkbox.checked;

    checkbox.addEventListener("change", () => {
      const checked = checkbox.checked;

      if (checked != lastCheck) {
        const currentTime = Math.floor(Date.now() / 1000);
        if (currentTime - lastTime > 0.5) {
          // 1 Second
          lastTime = currentTime;
          lastCheck = checked;
          sendXhr(checked);
        } else {
          console.log("fuck u, u are spamming us");
          iziToast.warning({ title: "Timeout", message: "Spam alert" });
          checkbox.value = lastCheck ? "on" : "off";
        }
      }
    });
  });
</script>

