{% extends 'bases/dashboard.jinja' %} {% load static %} {% block content %}
<script src="{% static 'vendor/iziToast/js/iziToast.js' %}"></script>

<div
  class="p-4 rounded-lg transition-all duration-300 bg-purple-200 dark:bg-[#0c0c0c]"
>
  {% include 'components/dashboard/breadcrumb.jinja' with current_page='Whitelist' %}
</div>

<script src="{% static 'vendor/iziToast/js/iziToast.js' %}"></script>

<div class="w-full bg-[#0D0D0D] p-6 rounded-xl mt-4" style="overflow-y: auto">
  <div class="flex items-center mb-4 md:mb-0 gap-3">
    <div>
      <div
        class="w-12 h-12 flex group items-center transition-all justify-center rounded-xl text-white group-hover:text-white bg-zinc-900 text-white transition-all duration-300"
      >
        <div
          class="flex items-center justify-center relative w-8 h-8 undefined"
        >
          <i class="absolute fas fa-list-check opacity-20"></i>
          <i class="absolute fa fa-list-check"></i>
        </div>
      </div>
    </div>
    <div class="w-full">
      <div class="flex items-center gap-1">
        <h3
          class="min-w-min text-white font-semibold text-sm md:text-lg line-clamp-1"
        >
          Whitelist
        </h3>
      </div>
      <h4 class="text-gray-400 text-sm">
        Here you can find out your server whitelisted players
      </h4>
    </div>
  </div>
  {% if whitelist_disabled %}
  <div
    class="text-yellow-700 mt-4 p-2 flex border-2 border-yellow-700 rounded-lg gap-2"
  >
    <i class="fa-solid fa-triangle-exclamation my-auto"></i>
    <p class="font-bold">
      Whitelist configuration is disabled, you can't add any whitelists. To use
      this feature please enable it in configurations section.
    </p>
  </div>
  {% endif %}
</div>
<div class="w-full p-4 justify-end flex">
  <button
    data-modal-target="add-whitelist-modal"
    data-modal-toggle="add-whitelist-modal"
    class="border-2 px-4 py-2 rounded-lg font-medium transition-all duration-300 text-gray-200 border-gray-200 hover:bg-gray-200 hover:text-black"
  >
    Add whitelist
  </button>
</div>

<div class="relative overflow-x-auto shadow-md sm:rounded-lg">
  <table
    class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400"
  >
    <thead
      class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-[#0d0d0d] dark:text-gray-400"
    >
      <tr>
        <th scope="col" class="px-6 py-3">NAME</th>
        <th scope="col" class="px-6 py-3">SERIAL</th>
        <th scope="col" class="pl-16 py-3">IP</th>
        <th scope="col" class="pl-16 py-3">Created At</th>
        <th scope="col" class="pl-16 py-3">Last Update At</th>
        <th scope="col" class="px-6 py-3">Actions</th>
      </tr>
    </thead>
    <tbody>
      {% for whitelist in whitelists %}
      <tr
        class="transition-all duration:300 bg-white border-b dark:bg-[#161616] dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-[#212121]"
      >
        <td class="px-6 py-4 font-medium">{{ whitelist.name }}</td>

        <th
          scope="row"
          class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white cursor-pointer"
          onclick="navigator.clipboard.writeText('{{ whitelist.key }}').then(() => iziToast.success({title: 'SUCCESS', message: 'Successfuly key copied to clipboard!'}))"
        >
          <span class="blur-sm hover:blur-0 transition duration-300">{{ whitelist.serial }}</span>
        </th>
        <td
          scope="row"
          class="pl-16 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white cursor-pointer"
          onclick="navigator.clipboard.writeText('{{ whitelist.key }}').then(() => iziToast.success({title: 'SUCCESS', message: 'Successfuly key copied to clipboard!'}))"
        >
          <span class="blur-sm hover:blur-0 transition duration-300">{{ whitelist.ip }}</span>
        </td>
        <td class="px-6 py-4">{{ whitelist.created_on }}</td>
        <td class="px-6 py-4">{{ whitelist.last_update_at }}</td>
        <td class="px-6 py-4 flex">
          {% if not whitelist_disabled %}
          <button
            onclick="document.getElementById('target-edit-whitelist').value = '{{ whitelist.id }}';
          document.getElementById('target-edit-whitelist-modal-name').textContent = '{{ whitelist.name }}';
          document.getElementById('edit-player-ip').value = '{{ whitelist.ip }}';
          document.getElementById('edit-player-serial').value = '{{ whitelist.serial }}';"
            data-modal-target="edit-whitelist-modal"
            data-modal-toggle="edit-whitelist-modal"
            data-tooltip-target="edit-whitelist-{{ whitelist.id }}"
            data-tooltip-style="dark"
            class="font-medium text-blue-600 dark:text-blue-500 hover:underline"
          >
            <i
              class="fa-solid fa-pen-to-square text-[#8c592b] transition-all duration-300 hover:bg-[#8c592b] hover:text-black rounded-full p-1"
            ></i>
          </button>
          {% endif %}

          <button
            onclick="document.getElementById('target-delete-whitelist').value = '{{ whitelist.id }}'; document.getElementById('target-delete-whitelist-modal-name').textContent = '{{ whitelist.name }}';"
            data-modal-target="delete-whitelist-modal"
            data-modal-toggle="delete-whitelist-modal"
            data-tooltip-target="remove-whitelist-{{ whitelist.id }}"
            data-tooltip-style="dark"
            class="font-medium text-blue-600 dark:text-blue-500 hover:underline"
          >
            <i
              class="fa-solid fa-xmark text-[#8c592b] transition-all duration-300 hover:bg-[#8c592b] hover:text-black rounded-full p-1"
            ></i>
          </button>

          {% if not whitelist_disabled %}
          <div
            id="edit-whitelist-{{ whitelist.id }}"
            role="tooltip"
            class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#8c592b] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300"
          >
            Edit Whitelist
            <div class="tooltip-arrow" data-popper-arrow></div>
          </div>
          {% endif %}

          <div
            id="remove-whitelist-{{ whitelist.id }}"
            role="tooltip"
            class="z-10 invisible inline-block px-3 py-2 text-sm font-medium text-black bg-[#8c592b] rounded-lg shadow-sm opacity-0 tooltip transition-all duration-300"
          >
            Delete Whitelist
            <div class="tooltip-arrow" data-popper-arrow></div>
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if whitelists|length == 0 %}
  <div
    class="transition-all duration:300 bg-white border-b dark:bg-[#161616] dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-[#181818] flex text-center"
  >
    <div
      scope="row"
      class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-gray-400 dark:hover:text-white w-full"
    >
      {{ error_message }}
    </div>
  </div>
  {% endif %}
</div>

<!-- Main modal -->
