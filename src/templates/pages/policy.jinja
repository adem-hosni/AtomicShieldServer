{% extends "bases/auth.jinja" %}
{% load static %}
{% block content %}
<div id="root">
  <div class="w-full bg-background-theme flex items-start flex-col noselect">
    <h1 class="hidden">Atomic Shield - Sign In</h1>
    <img src="./static/image/logo-ico.svg" alt="Atomic Shield" class="hidden" />
    {% include "components/header.jinja" %}
    <div class="flex py-12 self-stretch px-4 sm:px-8 md:px-12">
      <div class="w-full">
        <div class="min-h-[43rem] py-4 text-white self-stretch px-4">
          <section id="terms-of-service" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Terms of Service
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                By using Atomic Shield ("the Software"), you agree to the following terms:
              </p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li>
                  You may not use the Software for any unlawful or malicious purposes.
                </li>
                <li>
                  Unauthorized distribution, modification, or reverse engineering of the Software is strictly prohibited.
                </li>
                <li>
                  Atomic Shield is provided "as-is" without any warranties of any kind, express or implied.
                </li>
                <li>
                  We reserve the right to terminate your access to the Software at any time for violations of these terms.
                </li>
                <li>
                  These Terms of Service may be updated from time to time, and it is your responsibility to review them periodically.
                </li>
              </ul>
            </div>
          </section>
              <section id="tebex-terms" class="mb-12">
                <h2
                  class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4"
                >
                  Tebex Terms & Conditions
                </h2>
                <div class="shadow-md p-6 rounded-lg">
                  <p class="text-gray-300 mb-4">
                    We partner with Tebex Limited (<a href="https://www.tebex.io" class="text-blue-500">www.tebex.io</a>), who are the official merchant of digital content produced by us. If you wish to purchase licenses to use digital content we produce, you must do so through Tebex as our licensed reseller and merchant of record.
                  </p>
                  <p class="text-gray-300 mb-4">
                    In order to make any such purchase from Tebex, you must agree to their terms, available at <a href="https://checkout.tebex.io/terms" class="text-blue-500">https://checkout.tebex.io/terms</a>.
                  </p>
                  <p class="text-gray-300 mb-4">
                    If you have any queries about a purchase made through Tebex, including but not limited to refund requests, technical issues, or billing enquiries, you should contact Tebex support at <a href="https://www.tebex.io/contact/checkout" class="text-blue-500">https://www.tebex.io/contact/checkout</a> in the first instance.
                  </p>
                </div>
              </section>

          <section id="licensing" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Licensing & Usage
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Atomic Shield is provided under a license model. When purchasing access, you receive a non-transferable, non-exclusive, revocable license for use on a single FiveM server.
              </p>
              <p><strong>License Options:</strong></p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li>1 Month License</li>
                <li>3 Months License</li>
                <li>Lifetime License</li>
              </ul>
              <br>
              <p>License sharing, resale, or multi-server deployment under a single license is strictly prohibited.</p>
              <br>
              <p><strong>Prohibited Uses:</strong></p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li>Using Atomic Shield for cheat development or testing</li>
                <li>Reverse engineering or tampering with the software</li>
                <li>Redistributing, reselling, or rebranding the product</li>
                <li>Bypassing security or detection features</li>
              </ul>
              <br>
              <p><strong>Violations</strong> will result in immediate license termination and a permanent ban from the Atomic Shield network. No refunds will be granted.</p>
            </div>
          </section>

          <section id="refund-policy" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Refund Policy
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Refunds are not offered for digital products unless required by applicable law. If you experience technical issues with the Software, please contact our support team for resolution before requesting a refund.
              </p>
              <p class="text-gray-300 mb-4">
                Refund requests must be submitted in writing to <a href="mailto:support@atomicshield.com" class="text-blue-500">support@atomicshield.com</a>.
              </p>
            </div>
          </section>

          <section id="user-responsibilities" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              User Responsibilities & Conduct
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Atomic Shield includes features such as full desktop screenshot capabilities to detect external cheats. By using the software, you agree:
              </p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li>You are solely responsible for how you use detection features on your server</li>
                <li>You will comply with all applicable laws and FiveM rules</li>
                <li>You acknowledge that Atomic Shield only provides tools and is not liable for your decisions</li>
              </ul>
              <br>
              <p><strong>Support is available 24/7 via our Discord:</strong> <a href="https://discord.gg/atomic-shield" class="text-blue-500">discord.gg/atomic-shield</a></p>
            </div>
          </section>

          <section id="ban-policy" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Ban Policy & Enforcement
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Atomic Shield may revoke licenses without notice if Terms are violated. Violations include but are not limited to:
              </p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li>Multi server-ip use with one license</li>
                <li>Cheat development or reverse engineering</li>
                <li>Abuse of system functionality</li>
              </ul>
              <br>
              <p><strong>Ban System:</strong><br>
                Users may be banned at the hardware/account level across all servers using Atomic Shield. Appeals are accepted for false bans via Discord support.</p>
              <p><strong>Paid unbans</strong> may be offered in some cases for network-wide bans, but <strong>server-specific bans are solely controlled by each server owner.</strong></p>
            </div>
          </section>

          <section id="disclaimer" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Disclaimer & Limitation of Liability
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Atomic Shield is provided "as-is" with no warranty. While we aim for accuracy, false positives or server-side issues may occur. In such cases, we aim to resolve the issue before appeals are needed.
              </p>
              <p><strong>Atomic Shield is not liable</strong> for any server damage, false bans, data loss, or enforcement actions by third parties (e.g., FiveM).</p>
            </div>
          </section>

          <section id="changes-to-terms" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Changes to Terms
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                We may modify these Terms at any time. Changes will be posted via the Atomic Shield dashboard and Discord. Continued use of the service means you accept the updated Terms.
              </p>
            </div>
          </section>

          <section id="contact" class="mb-12">
            <h2 class="text-4xl text-gray-300 font-extrabold tracking-tight pl-4 mb-4">
              Contact
            </h2>
            <div class="shadow-md p-6 rounded-lg">
              <p class="text-gray-300 mb-4">
                Questions or appeals? You can reach us through:
              </p>
              <ul class="list-disc list-inside space-y-2 text-gray-300">
                <li><strong>Discord:</strong> <a href="https://discord.gg/atomic-shield" class="text-blue-500">discord.gg/atomic-shield</a></li>
              </ul>
            </div>
          </section>
        </div>
      </div>
    </div>
    {% include "components/footer.jinja" %}
  </div>
</div>
{% endblock content %}
